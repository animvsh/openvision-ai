# OpenVision AI Backend Configuration

# Server
PORT=3001

# AWS Configuration (optional - mock data used when not configured)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# DynamoDB Tables
EVENTS_TABLE=openvision-events
CAMERAS_TABLE=openvision-cameras
SESSIONS_TABLE=openvision-sessions

# Cognito (optional - mock auth used when not configured)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
AUTO_CONFIRM_USERS=true

# WebSocket
WEBSOCKET_URL=

# CORS
CORS_ORIGINS=*

# JWT
JWT_SECRET=openvision-dev-secret-change-in-production

# Environment
NODE_ENV=development