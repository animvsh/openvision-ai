# OpenVision AI Platform - Environment Configuration
# Copy this file to .env and fill in the values

# ===========================================
# SHARED AWS CONFIGURATION
# ===========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ===========================================
# DASHBOARD (apps/dashboard)
# ===========================================
# Frontend API URL - points to backend service
VITE_API_URL=http://backend.railway.internal:3001
VITE_WS_URL=ws://backend.railway.internal:3001/ws

# ===========================================
# BACKEND (apps/backend)
# ===========================================
PORT=3001
NODE_ENV=production

# JWT Secret - generate with: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-here

# CORS Origins - space-separated list
CORS_ORIGINS=http://dashboard.railway.internal

# DynamoDB Tables
DYNAMODB_TABLE_CAMERAS=openvision-cameras
DYNAMODB_TABLE_EVENTS=openvision-events
DYNAMODB_TABLE_ALERTS=openvision-alerts

# SNS for notifications (optional)
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:openvision-alerts
SQS_QUEUE_URL=

# Telegram alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Email alerts via SES (optional)
SES_FROM_EMAIL=alerts@openvision.ai
SES_TO_EMAILS=admin@openvision.ai

# ===========================================
# API SERVICE (services/api)
# ===========================================
# PostgreSQL Database (via Railway PostgreSQL plugin)
# The DATABASE_URL is auto-injected when you add the plugin
DATABASE_URL=postgresql://postgres:password@db.railway.internal:5432/openvision

# Alternative individual DB vars (if not using DATABASE_URL)
DB_HOST=db.railway.internal
DB_PORT=5432
DB_NAME=openvision
DB_USER=postgres
DB_PASSWORD=your-secure-password

# AWS DynamoDB
DYNAMODB_TABLE=VideoProcessingJobs
CAMERA_STATE_TABLE=CameraState
EVENTS_TABLE=Events

# Kinesis Streams
KINESIS_STREAM=DetectionEvents

# Cognito (optional - for JWT validation)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# API Configuration
API_STAGE=production

# ===========================================
# RULES ENGINE (services/rules-engine)
# ===========================================
# Uses AWS DynamoDB and SNS
CAMERA_STATE_TABLE=CameraState
EVENTS_TABLE=Events

# ===========================================
# AI SUMMARY (services/ai-summary)
# ===========================================
# Anthropic API Key for Claude via Bedrock
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional - Bedrock Agent configuration
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# ===========================================
# VIDEO PROCESSOR (services/video-processor)
# ===========================================
# DynamoDB Table
DYNAMODB_TABLE=VideoProcessingJobs

# Kinesis Stream
KINESIS_STREAM=DetectionEvents

# S3 Bucket for video storage
S3_BUCKET=openvision-videos

PORT=8080